rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isCashier() {
      return isAuthenticated() && getUserData().role == 'cashier';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    // User profiles
    match /users/{userId} {
      // Users can read their own profile
      // Cashiers can read student profiles to verify IDs
      allow read: if isOwner(userId) || isCashier();
      
      // Only system/admins should create, but for this demo users create their own on first login
      allow create: if isOwner(userId) && 
                    request.resource.data.keys().hasAll(['uid', 'email', 'role', 'balance']) &&
                    request.resource.data.role in ['student', 'cashier'];
      
      // Cashiers can update student balances (loads)
      // Students can update their own balance ONLY for payments (deductions)
      allow update: if isCashier() || (isOwner(userId) && request.resource.data.balance <= resource.data.balance);
    }

    // Transactions
    match /transactions/{transactionId} {
      // Students can read their own transactions
      // Cashiers can read all transactions
      allow read: if isCashier() || (isAuthenticated() && 
                    (resource.data.studentId == request.auth.uid || resource.data.cashierId == request.auth.uid));
      
      // Cashiers can create load transactions
      // Students can create payment transactions
      allow create: if (isCashier() && request.resource.data.type == 'load') ||
                    (isOwner(request.resource.data.studentId) && request.resource.data.type == 'payment');
      
      allow update, delete: if false; // Ledger is immutable
    }

    // Top-up Requests
    match /topup_requests/{requestId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isCashier());
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId) && 
                    request.resource.data.status == 'pending';
      allow update: if isCashier();
      allow delete: if isOwner(resource.data.studentId) && resource.data.status == 'pending';
    }
  }
}

{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user roles and current balances.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["cashier", "student"] },
        "balance": { "type": "number", "description": "Current account balance" },
        "studentId": { "type": "string", "description": "Official school student ID" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Ledger entries for balance loads and payments.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The student receiving or paying" },
        "cashierId": { "type": "string", "description": "The cashier who processed the load (optional for payments)" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["load", "payment"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["studentId", "amount", "type", "timestamp"]
    },
    "TopupRequest": {
      "title": "Top-up Request",
      "description": "Requests from students to load their balance.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["Gcash", "Over-the-Counter", "Bank Transfer"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "amount", "method", "status", "timestamp"]
    },
    "LoadRequest": {
      "title": "QR Load Request",
      "description": "QR-based load requests for over-the-counter processing.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "amount", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and balances"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial ledger"
    },
    "/topup_requests/{requestId}": {
      "schema": "TopupRequest",
      "description": "Pending and historical top-up requests"
    },
    "/load_requests/{requestId}": {
      "schema": "LoadRequest",
      "description": "QR-based load requests"
    }
  }
}
